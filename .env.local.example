# Copy to .env.local. Restart `pnpm dev` after changes.
#
# NOTE: NEXT_PUBLIC_* only configures where the portal calls your Asterisk HTTP API (and SIP hints in the UI).
# It does NOT change the “Network” URL Next.js prints for the dev server. That URL comes from your PC’s
# network adapters (VirtualBox/Hyper-V often shows 192.168.56.x). The dev server listens on all interfaces
# (0.0.0.0); open http://<your-LAN-IPv4>:3000 — run `ipconfig` and use the address on the same subnet as your PBX.

# Default behavior (no host set): auto-use current browser hostname.
# Example: opening portal at http://192.168.1.25:3000 makes API default to http://192.168.1.25:3001/api
#
# Optional override: one fixed IP/hostname for both SIP softphone and HTTP API.
# Use host only (no /24 CIDR). Your PBX is 10.118.64.147 on subnet 10.118.64.0/24.

NEXT_PUBLIC_ASTERISK_HOST=192.168.1.80

# Optional: API port on that host (default 3001)
# NEXT_PUBLIC_ASTERISK_API_PORT=3001
NEXT_PUBLIC_ASTERISK_API_PORT=3001

# Optional: SIP signaling port shown in the portal (default 5060)
# NEXT_PUBLIC_ASTERISK_SIP_PORT=5060
NEXT_PUBLIC_ASTERISK_SIP_PORT=5060

# Optional: full API base URL (overrides HOST + API_PORT if set).
# Use the root URL of your *bridge* app (users/extensions/login), NOT bare ARI (/ari) unless your bridge is mounted there.
# NEXT_PUBLIC_ASTERISK_API=http://10.118.64.147:3001/api
NEXT_PUBLIC_ASTERISK_API=http://192.168.1.80:3001/api

# Optional: SIP server shown in UI if different from HOST
# NEXT_PUBLIC_ASTERISK_SIP_SERVER=10.118.64.147
NEXT_PUBLIC_ASTERISK_SIP_SERVER=192.168.1.80

# ─── Bridge path overrides (optional) ──────────────────────────────────────
# Defaults match Asterisk ARI for: endpoints, channels, asterisk/info
# and common REST names for: login, users, extensions, nextextension, …
# Uncomment and edit only if your bridge uses different URL segments.
#
# NEXT_PUBLIC_BRIDGE_PATH_ENDPOINTS=endpoints
# NEXT_PUBLIC_BRIDGE_PATH_CHANNELS=channels
# NEXT_PUBLIC_BRIDGE_PATH_ASTERISK_INFO=asterisk/info
# NEXT_PUBLIC_BRIDGE_PATH_INFO=info
# NEXT_PUBLIC_BRIDGE_PATH_LOGIN=login
# NEXT_PUBLIC_BRIDGE_PATH_USERS=users
# NEXT_PUBLIC_BRIDGE_PATH_EXTENSIONS=extensions
# NEXT_PUBLIC_BRIDGE_PATH_NEXT_EXTENSION=nextextension
# NEXT_PUBLIC_BRIDGE_PATH_SYSTEM=system
# NEXT_PUBLIC_BRIDGE_PATH_AUDIT=audit
# NEXT_PUBLIC_BRIDGE_PATH_SECURITY=security
# NEXT_PUBLIC_BRIDGE_PATH_REALCDR=realcdr
# NEXT_PUBLIC_BRIDGE_PATH_CDR=cdr
# NEXT_PUBLIC_BRIDGE_PATH_VOICEMAIL=voicemail

# ─── POST /extensions body (optional) ─────────────────────────────────────
# If your bridge returns HTTP 500 when extra JSON keys are present, try:
# NEXT_PUBLIC_BRIDGE_EXTENSION_MINIMAL_BODY=true
# Many PJSIP bridges need dialplan context / driver name — set to match *your* server:
# NEXT_PUBLIC_BRIDGE_EXTENSION_CONTEXT=from-internal
# NEXT_PUBLIC_BRIDGE_EXTENSION_TECHNOLOGY=pjsip